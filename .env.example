# =============================================================================
# BioMaxing Social Marketing Service — Environment Variables
# =============================================================================
# Copy to .env and fill in your values:  cp .env.example .env

# --- Track / Brand -----------------------------------------------------------
TRACK=eu                          # 'eu' (BioMaxing) or 'ru' (Vitabi)
LANGUAGE=en                       # 'en' or 'ru'
BRAND_NAME=BioMaxing
CONTENT_TONE=scientific_casual    # 'scientific_casual' or 'accessible_preventive'
DEFAULT_HASHTAGS=#biohacking,#supplements,#health,#wellness,#biomaxing

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://social:social_dev_pass@postgres:5432/social_marketing
# Used by docker-compose postgres service:
DB_USER=social
DB_PASSWORD=social_dev_pass

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Telegram ----------------------------------------------------------------
TG_BOT_TOKEN=                     # Bot token from @BotFather
TG_ADMIN_CHAT_ID=0                # Chat ID where admin reviews posts
TG_ADMIN_THREAD_ID=               # Topic/thread ID for supergroups (leave empty if not using topics)
TG_CHANNEL_ID=0                   # Channel ID to publish to
TG_ADMIN_USER_IDS=                # Comma-separated Telegram user IDs, e.g. 123456789,987654321

# --- OpenRouter (text & image generation) ------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEXT_MODEL=anthropic/claude-sonnet-4-20250514
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# --- Media Storage -----------------------------------------------------------
MEDIA_STORAGE_PATH=/app/media
MEDIA_BASE_URL=                   # Public URL prefix for Instagram, e.g. https://media.yourdomain.com

# --- OpenAI (video pipeline) ------------------------------------------------
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5-mini           # Used for video script planning
OPENAI_IMAGE_MODEL=gpt-image-1-mini    # Used for video scene images
OPENAI_VIDEO_MODEL=sora-2              # Used for motion clip generation
OPENAI_TTS_MODEL=gpt-4o-mini-tts      # Text-to-speech for voiceover
OPENAI_TTS_VOICE=alloy                 # TTS voice: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TRANSCRIBE_MODEL=whisper-1      # Speech-to-text for subtitles

# --- Video Settings ----------------------------------------------------------
VIDEO_SIZE=720x1280               # Resolution for motion clips
VIDEO_QUALITY=standard            # 'standard' or 'hd'
VIDEO_DEFAULT_MOTION_SECONDS=8    # Default duration for motion scenes
VIDEO_MIN_SCENE_SECONDS=5
VIDEO_MAX_SCENE_SECONDS=10
VIDEO_FINAL_TARGET_SECONDS=36     # Target total video duration
VIDEO_MOTION_SCENE_COUNT=3        # Number of AI-generated motion clips
VIDEO_STILL_SCENE_COUNT=2         # Number of still-image scenes
VIDEO_FPS=30
VIDEO_ENABLE_MOTION=true          # Set to 'false' for cheap mode (still images only, no sora-2)

# --- Brand (video slide overlays) -------------------------------------------
BRAND_HEADING_FONT=               # Path to heading font .ttf (e.g. templates/fonts/Jura-Bold.ttf)
BRAND_BODY_FONT=                  # Path to body font .ttf (e.g. templates/fonts/Inter-Regular.ttf)
BRAND_LOGO_PATH=                  # Path to logo .png (optional, shown on video slides)
BRAND_PRIMARY_TEAL=#53D7FF
BRAND_BG=#06141A
BRAND_TEXT_COLOR=#F5FBFF
BRAND_SUBTLE_TEXT=#D6EDF4

# --- Audio (video background music) -----------------------------------------
BGM_PATH=                         # Path to background music .wav (optional)
BGM_VOLUME=0.10                   # 0.0 to 1.0
VOICE_VOLUME=1.00                 # 0.0 to 1.0

# --- fal.ai (reserved for future use) ---------------------------------------
FAL_API_KEY=

# --- Instagram ---------------------------------------------------------------
INSTAGRAM_ACCESS_TOKEN=           # Long-lived token from Meta Graph API
INSTAGRAM_BUSINESS_ACCOUNT_ID=    # Instagram Business Account ID
INSTAGRAM_GRAPH_API_URL=https://graph.facebook.com/v22.0

# --- YouTube -----------------------------------------------------------------
YOUTUBE_CLIENT_ID=                # From Google Cloud Console OAuth 2.0 credentials
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=            # Obtained via scripts/setup_oauth.py
